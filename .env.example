# ============================================================
# Razkindo ERP - Environment Configuration (TEMPLATE)
# Copy this file to .env and fill in your values
# ============================================================

# Database - Supabase PostgreSQL
# PgBouncer (connection pooling) untuk Prisma Client runtime queries
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true

# Direct connection untuk migrations (session mode port 5432)
DIRECT_URL=postgresql://postgres:[YOUR-PASSWORD]@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres

# Direct connection ke Supabase database (tanpa pooler)
SUPABASE_DB_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# ============================================================
# SUPABASE REST API (for @supabase/supabase-js)
# ============================================================
NEXT_PUBLIC_SUPABASE_URL=https://[YOUR-PROJECT-REF].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ============================================================
# AUTH (Custom HMAC-based, NOT NextAuth)
# ============================================================
AUTH_SECRET=your-secret-key-change-in-production

# ============================================================
# WEBSOCKET / EVENT QUEUE SERVICE
# ============================================================
# Shared secret between Next.js and event-queue service (REQUIRED)
WS_SECRET=your-ws-secret-change-in-production
# URL of the event-queue service (default: http://127.0.0.1:3004)
EVENT_QUEUE_URL=http://127.0.0.1:3004
# Optional: Explicit WebSocket URL for client-side (leave empty for auto-detect)
# NEXT_PUBLIC_WS_URL=http://your-server-ip:3004

# ============================================================
# PUSH NOTIFICATIONS (optional)
# ============================================================
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key
# VAPID_PRIVATE_KEY=your_vapid_private_key
# VAPID_SUBJECT=mailto:your@email.com

# ============================================================
# PRODUCTION
# ============================================================
NODE_ENV=production
NEXT_TELEMETRY_DISABLED=1
